{
  "name": "bulldog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron dist-electron/main.cjs",
    "watch:electron": "tsc -p electron/tsconfig.json --watch",
    "build:electron": "tsc -p electron/tsconfig.json && node electron/scripts/postbuild.cjs",
    "dev": "npm run build:electron && concurrently -k -n vite,tsc,electron -c blue,yellow,green \"npm:dev:vite\" \"npm:watch:electron\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "build": "tsc -b && vite build && npm run build:electron",
    "preview": "vite preview",
    "start": "electron dist-electron/main.cjs",
    "typecheck": "tsc -b --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/rapier": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "three": "^0.169.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
